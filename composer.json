{
    "name": "w4/native",
    "description": "Paquete de componentes de Interfaz de Usuario para aplicaciones empresariales inspirados en DaisyUI para Laravel PHP.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "w4-software",
        "laravel",
        "daisyui",
        "ui-framework",
        "components"
    ],
    "autoload": {
        "psr-4": {
            "W4\\Native\\Daisy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "W4\\Native\\Daisy\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Francisco J. Morales", 
            "email": "franciscomorales@w4.software",
            "role": "Developer",
            "homepage": "https://w4.software/packages"
        }
    ],
    "require": {
        "php": "^8.3",
        "composer/installers": "^2.0",
        "gehrisandro/tailwind-merge-php": "^1.2",
        "laravel/framework": "^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "phpunit/phpunit": "^11.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "W4\\Native\\Daisy\\Providers\\NativeDaisyServiceProvider" 
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "optimize-autoloader": true,
        "allow-plugins": {
            "composer/installers": true
        }
    },
    "scripts": {
        "test": "phpunit --colors=always"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
